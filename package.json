{
  "name": "plane-cli",
  "version": "0.1.0",
  "description": "Machine-friendly TypeScript CLI for Plane.so.",
  "keywords": [
    "agents",
    "automation",
    "cli",
    "llm",
    "plane",
    "typescript"
  ],
  "license": "MIT",
  "bin": {
    "plane-cli": "./bin/plane-cli"
  },
  "files": [
    "bin",
    "dist/index.js",
    "dist/index.d.ts",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist && bun build src/index.ts --compile --outfile dist/plane-cli",
    "ci": "bun run test && bun run build && bun run lint",
    "dev": "tsx src/index.ts",
    "lint": "oxlint .",
    "prepack": "bun run build",
    "format": "oxfmt --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
